{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "VynMindMap",
  "version": "0.1.0",
  "identifier": "com.vynmm.mindmap",
  "build": {
    "frontendDist": "../dist-app",
    "devUrl": "http://localhost:5183",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build:app"
  },
  "app": {
    "windows": [
      {
        "title": "VynMindMap",
        "width": 1100,
        "height": 740,
        "minWidth": 640,
        "minHeight": 480
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "fileAssociations": [
      {
        "ext": ["vmm"],
        "name": "VynMindMap",
        "description": "VynMindMap mind map",
        "role": "Editor"
      }
    ]
  }
}
