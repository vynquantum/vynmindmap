{
  "name": "vynmm-core",
  "version": "0.1.0",
  "description": "Core model and .vmm file format for VynMM mind-mapping app",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "examples": "tsx scripts/make-examples.ts",
    "dev": "vite",
    "build:app": "vite build",
    "preview": "vite preview",
    "check": "svelte-check --tsconfig ./tsconfig.app.json",
    "tauri": "tauri",
    "app:dev": "tauri dev",
    "app:build": "tauri build",
    "make:icon": "tsx scripts/make-icon.ts",
    "vynmm": "tsx src/cli.ts",
    "mcp": "tsx mcp/server.ts"
  },
  "bin": {
    "vynmm": "dist/cli.js"
  },
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@tauri-apps/api": "^2.1.1",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "fflate": "^0.8.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^5.0.3",
    "@tauri-apps/cli": "^2.1.0",
    "@tsconfig/svelte": "^5.0.4",
    "@types/node": "^26.0.1",
    "svelte": "^5.16.0",
    "svelte-check": "^4.1.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vite": "^6.0.7",
    "vitest": "^3.0.5"
  }
}
